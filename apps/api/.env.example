DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
JWT_SECRET=generate-a-secure-random-string-here
NODE_ENV=development
PORT=4000
JWT_EXPIRES_IN=7d
CORS_ORIGINS=https://expograph.in,https://www.expograph.in,http://localhost:5173,http://localhost:4173
DEFAULT_TENANT_SLUG=expograph

# Razorpay (required for payments)
RAZORPAY_KEY_ID=rzp_live_xxx
RAZORPAY_KEY_SECRET=xxx
RAZORPAY_WEBHOOK_SECRET=xxx
# Platform fee: percentage added at checkout (default 7). Set PLATFORM_FEE_PERCENT=0 to disable.
# PLATFORM_FEE_PERCENT=7

# Payment redirects and callbacks:
# PUBLIC_API_URL - Must be reachable from the user's browser (for Razorpay callback_url).
#   Dev: http://localhost:4000
#   Prod: https://api.expograph.in (your API's public URL)
# PUBLIC_WEB_URL - Fallback for redirects when frontend doesn't send origin.
#   Dev: http://localhost:5173
#   Prod: https://expograph.in
PUBLIC_WEB_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:4000

# Resend for OTP and verification emails (https://resend.com)
# Use the same RESEND_FROM for both login and verification so deliverability matches.
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM=ExpoGraph <noreply@yourdomain.com>
# Optional: reply-to. Same for login and verify.
# RESEND_REPLY_TO=support@yourdomain.com
# Optional: verification fallback link base (must match sending domain). If set, verification email includes a link.
# RESEND_VERIFY_LINK_BASE=https://notifications.yourdomain.com
# Set to true to send verification email with OTP only (no fallback link).
# DISABLE_VERIFY_FALLBACK_LINK=true

# Cloudflare Stream (for video hosting)
CF_ACCOUNT_ID=your-cloudflare-account-id
CF_API_TOKEN=your-cloudflare-api-token
VIDEO_UID=your-default-video-uid
CF_STREAM_CUSTOMER_CODE=customer-xxxxxxxx
